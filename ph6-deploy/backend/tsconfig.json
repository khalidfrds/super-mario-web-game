{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "types": ["node"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["./**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
